#!/usr/bin/env bash
# Owner Operator launcher — TypeScript runtime via tsx (pi SDK is the engine).
#   ./harness/oo                      → branded TUI (interactive, pi-tui)
#   ./harness/oo "what's ongoing?"    → plain one-shot
#   OO_MODEL / .pi/settings.json      → model (default: codex gpt-5.5)
DIR="$(dirname "$0")"
if [ "$#" -gt 0 ]; then
  exec npx tsx "$DIR/src/oo.ts" "$@"
else
  exec npx tsx "$DIR/src/tui.ts"
fi
