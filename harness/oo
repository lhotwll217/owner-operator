#!/usr/bin/env bash
# Owner Operator launcher — TypeScript runtime via tsx (pi SDK is the engine).
#   ./harness/oo                      → chat (pi's stock interactive mode, our agent config)
#   ./harness/oo --tui                → branded TUI with the pinned sidebar (A/B surface)
#   OO_TUI=1 ./harness/oo             → same, via env
#   ./harness/oo "what's ongoing?"    → plain one-shot
#   ./harness/oo one-shot "question"  → single agent-to-agent turn (read-only channel), text out;
#                                       --continue / --session <id> resume a persisted thread
#   OO_MODEL / .pi/settings.json      → model (default: codex gpt-5.5)
# Works from the repo and when installed on PATH via `npm link` (resolves the symlink).

# Resolve symlinks so DIR is the real harness dir even when run as a linked global bin.
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  D="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [ "${SOURCE#/}" = "$SOURCE" ] && SOURCE="$D/$SOURCE"
done
DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"

# Interactive mode is the default. The branded TUI is opt-in: an explicit --tui flag
# (consumed here, not forwarded) or OO_TUI=1. -i/--interactive stays as a no-op alias.
TUI="${OO_TUI:-}"
if [ "$1" = "--tui" ]; then
  TUI=1
  shift
elif [ "$1" = "-i" ] || [ "$1" = "--interactive" ]; then
  shift
fi

if [ "$1" = "one-shot" ]; then
  ENTRY="$DIR/src/agent/one-shot.ts"     # single agent-to-agent turn on the same read-only channel
  shift                            # drop the subcommand; the rest is the prompt
elif [ -n "$TUI" ]; then
  ENTRY="$DIR/src/tui/tui.ts"
elif [ "$#" -gt 0 ]; then
  ENTRY="$DIR/src/cli/oo.ts"
else
  ENTRY="$DIR/src/tui/interactive.ts"
fi

# Prefer the checkout's tsx (workspace-hoisted to repo root); fall back to npx.
if [ -x "$DIR/node_modules/.bin/tsx" ]; then
  exec "$DIR/node_modules/.bin/tsx" "$ENTRY" "$@"
elif [ -x "$DIR/../node_modules/.bin/tsx" ]; then
  exec "$DIR/../node_modules/.bin/tsx" "$ENTRY" "$@"
else
  exec npx tsx "$ENTRY" "$@"
fi
