{
  "name": "@owner-operator/harness",
  "version": "0.1.0",
  "private": true,
  "description": "Owner Operator — an opinionated local chief-of-staff agent built on the pi SDK.",
  "type": "module",
  "bin": { "oo": "./oo" },
  "scripts": {
    "oo": "tsx src/oo.ts",
    "tui": "tsx src/tui.ts",
    "interactive": "tsx src/interactive.ts",
    "preview": "tsx src/cards.preview.ts",
    "preview:brief": "tsx src/brief.preview.ts",
    "preview:sidebar": "tsx src/sidebar.preview.ts",
    "preview:screen": "tsx src/screen.preview.ts",
    "preview:chat": "tsx src/chat.preview.ts",
    "poll:smoke": "tsx src/poller.smoke.ts",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:unit": "node test/run.mjs unit",
    "test:integration": "node test/run.mjs integration",
    "test:e2e": "node test/run.mjs e2e",
    "test:poller": "tsx src/poller.integration.test.ts",
    "test:scan": "tsx src/scan.integration.test.ts",
    "test:store": "tsx src/store.test.ts",
    "test:daemon": "tsx src/daemon.e2e.test.ts",
    "test:agent": "tsx src/agent.behavior.ts",
    "test:db": "tsx src/threads-db.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@owner-operator/core": "*",
    "@earendil-works/pi-coding-agent": "0.78.0",
    "@earendil-works/pi-ai": "0.78.0",
    "@earendil-works/pi-tui": "0.78.0"
  },
  "devDependencies": {
    "@types/node": "^24",
    "tsx": "^4",
    "typescript": "^5"
  }
}
