{
  "name": "@owner-operator/harness",
  "version": "0.1.0",
  "private": true,
  "description": "Owner Operator — an opinionated local chief-of-staff agent built on the pi SDK.",
  "type": "module",
  "bin": { "oo": "./oo" },
  "scripts": {
    "oo": "tsx src/cli/oo.ts",
    "tui": "tsx src/tui/tui.ts",
    "interactive": "tsx src/tui/interactive.ts",
    "preview": "tsx src/shared/cards.preview.ts",
    "preview:brief": "tsx src/tui/brief.preview.ts",
    "preview:sidebar": "tsx src/tui/sidebar.preview.ts",
    "preview:screen": "tsx src/tui/screen.preview.ts",
    "preview:chat": "tsx src/tui/chat.preview.ts",
    "poll:smoke": "npm --workspace @owner-operator/gateway run poll:smoke",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:unit": "node test/run.mjs unit",
    "test:integration": "node test/run.mjs integration",
    "test:e2e": "node test/run.mjs e2e",
    "test:poller": "npm --workspace @owner-operator/gateway run test:poller",
    "test:scan": "tsx test/scan.integration.test.ts",
    "test:store": "npm --workspace @owner-operator/gateway run test:store",
    "test:daemon": "npm --workspace @owner-operator/gateway run test:daemon",
    "test:agent": "tsx src/agent/agent.behavior.ts",
    "test:db": "npm --workspace @owner-operator/gateway run test:db",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@owner-operator/core": "*",
    "@owner-operator/gateway": "*",
    "@earendil-works/pi-coding-agent": "0.78.0",
    "@earendil-works/pi-ai": "0.78.0",
    "@earendil-works/pi-tui": "0.78.0"
  },
  "devDependencies": {
    "@types/node": "^24",
    "tsx": "^4",
    "typescript": "^5"
  }
}
