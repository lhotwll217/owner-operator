{
  "name": "owner-operator",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Local-first chief of staff over your CLI agent sessions, built on the pi coding agent toolkit.",
  "license": "MIT",
  "bin": {
    "oo": "./oo"
  },
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "oo": "tsx src/cli/oo.ts",
    "interactive": "tsx src/cli/interactive.ts",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e && npm run test --workspaces --if-present",
    "test:unit": "node test/run.mjs unit",
    "test:integration": "node test/run.mjs integration",
    "test:e2e": "node test/run.mjs e2e",
    "test:agent": "tsx src/agent/agent.behavior.ts",
    "eval": "node eval/loop.mjs --full",
    "eval:loop": "node eval/loop.mjs",
    "eval:compare": "node eval/compare.mjs",
    "poll:smoke": "tsx src/session-monitor/monitor.smoke.ts",
    "typecheck": "tsc --noEmit && npm run typecheck --workspaces --if-present",
    "lint": "oxlint --deny-warnings"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "0.80.6",
    "@earendil-works/pi-coding-agent": "0.80.6",
    "@earendil-works/pi-tui": "0.80.6",
    "@owner-operator/core": "*",
    "@thurstonsand/pi-permissions": "0.8.0",
    "croner": "10.0.1"
  },
  "devDependencies": {
    "@types/node": "^24",
    "oxlint": "^1.72.0",
    "promptfoo": "0.121.18",
    "tsx": "^4",
    "typescript": "^5"
  }
}
